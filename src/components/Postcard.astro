---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category?: string;
  slug: string;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
}

const {
  title,
  excerpt,
  date,
  category = "Blog",
  slug,
  heroImage,
  heroImageAlt = title
} = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col bg-pink-soft border-2 border-pink-dark rounded-2xl p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark hover:shadow-[1px_1px_0px_0px_rgba(0,0,0,1)] hover:shadow-pink-dark hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-150"
>

  <div class="border-2 border-pink-dark rounded-xl h-36 w-full overflow-hidden relative mb-4 flex items-center justify-center bg-pink-light/30 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark">
    {heroImage ? (
      <Image
        src={heroImage}
        alt={heroImageAlt || title}
        width={400}
        height={225}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 filter saturate-[1.02]"
      />
    ) : (
      <div class="w-full h-full bg-[linear-gradient(to_right,rgba(255,182,193,0.1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,182,193,0.1)_1px,transparent_1px)] bg-size-[10px_10px] flex flex-col items-center justify-center text-pink-dark/40 gap-1 select-none">
        <span class="text-xl">✿</span>
        <span class="font-mono text-[9px] tracking-wider uppercase">img_void</span>
      </div>
    )}
  </div>

  <div class="flex items-center gap-2 mb-3">
    <span class="bg-pink-light text-pink-dark border-2 border-pink-dark font-display text-[9px] font-black uppercase tracking-widest px-2.5 py-0.5 rounded shadow-[1.5px_1.5px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark">
      📂 {category}
    </span>
  </div>

  <h2 class="font-display font-black text-pink-dark text-base leading-snug mb-2 group-hover:text-pink-main transition-colors line-clamp-2">
    {title}
  </h2>

  <p class="font-body text-xs text-pink-ink/90 leading-relaxed mb-4 grow line-clamp-3 border-l-2 border-pink-mid/50 pl-2.5">
    {excerpt}
  </p>

  <div class="flex items-center justify-between mt-auto pt-3 border-t-2 border-dashed border-pink-light/60">
    <div class="flex items-center gap-1 font-mono text-[10px] font-bold text-pink-dark/70">
      <span>log//</span>
      <FormattedDate date={date} />
    </div>

    <span class="bg-pink-main text-pink-soft border-2 border-pink-dark font-display text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-lg shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark group-hover:bg-pink-dark group-hover:text-pink-soft transition-all duration-150">
        Abrir
    </span>
  </div>
</a>
