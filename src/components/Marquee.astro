---
const items = ['lifestyle', 'travel', 'food & recipes', 'musings', 'design', 'slow living'];
const doubled = [...items, ...items];
---

<div class="w-full bg-pink-light/40 border-y-4 border-pink-dark overflow-hidden py-4 select-none relative">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,182,193,0.1)_1px,transparent_1px)] bg-size-[20px_1px] pointer-events-none"></div>

  <div class="flex whitespace-nowrap animate-marquee items-center relative z-10">
    {doubled.map(item => (
      <div class="inline-flex items-center gap-4 px-3">
        <span class="bg-pink-soft text-pink-dark border-2 border-pink-dark font-display font-black text-xs uppercase tracking-widest px-4 py-2 rounded-xl shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark">
          {item}
        </span>
        <span class="text-pink-main text-xl font-sans drop-shadow-[1px_1px_0px_rgba(0,0,0,1)]">✦</span>
      </div>
    ))}
  </div>
</div>

<style>
@keyframes marquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.animate-marquee { animation: marquee 20s linear infinite; }
</style>
