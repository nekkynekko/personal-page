---
import { Image } from 'astro:assets';
import myIcon from '../../public/favicon_original.png';

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};

const navLinks = [
  { label: "Inicio", href: "/" },
  //{ label: "Posts", href: "/blog"}
  { label: "About", href: "/about" },
];
---

<header class="bg-pink-page w-full relative z-50 border-b-4 border-pink-dark">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-4 flex items-center justify-between gap-4">

      <a href="/" class="group flex items-center gap-3 font-display font-black text-2xl text-pink-dark tracking-wider hover:text-pink-main transition-colors drop-shadow-[2px_2px_0px_rgba(0,0,0,0.1)]">
        <Image
          src={myIcon}
          alt="NekkyNekko Logo"
          class="w-10 h-10 rounded-full border-2 border-pink-dark shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark group-hover:scale-105 transition-transform duration-150 object-cover"
        />
        <span>NekkyNekko</span>
      </a>

    <nav class="hidden md:flex bg-pink-light/40 border-2 border-pink-dark rounded-xl p-1 gap-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-display font-black text-xs uppercase tracking-wider px-4 py-2 rounded-lg border-2 transition-all duration-150",
            isActive(link.href)
              ? "bg-pink-main text-pink-soft border-pink-dark shadow-[1px_1px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark"
              : "text-pink-dark border-transparent hover:bg-white/50 hover:border-pink-dark/30"
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a
        href="https://nekkynekko.substack.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-block bg-pink-main text-pink-soft border-2 border-pink-dark font-display font-black text-xs uppercase tracking-wider px-5 py-2.5 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark hover:bg-pink-dark hover:text-pink-soft hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-0.5 hover:translate-y-0.5 active:translate-x-1 active:translate-y-1 active:shadow-none transition-all duration-150"
      >
        Substack ✦
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-pink-dark bg-pink-soft border-2 border-pink-dark rounded-xl shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark active:translate-x-0.5 active:translate-y-0.5 active:shadow-none transition-all focus:outline-none"
        aria-label="Toggle Menu"
      >
        <svg id="icon-menu" class="w-6 h-6 block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden absolute top-full left-0 w-full bg-pink-page border-b-4 border-pink-dark overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0 pointer-events-none z-50"
  >
    <div class="px-4 pt-2 pb-6 bg-[linear-gradient(to_right,rgba(255,182,193,0.1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,182,193,0.1)_1px,transparent_1px)] bg-size-[12px_12px]">
      <nav class="flex flex-col bg-pink-soft border-2 border-pink-dark rounded-2xl p-2 gap-1.5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-display font-black text-xs uppercase tracking-wider px-4 py-3 rounded-xl text-center border-2 transition-all duration-150",
              isActive(link.href)
                ? "bg-pink-main text-pink-soft border-pink-dark shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark"
                : "text-pink-dark border-transparent hover:bg-pink-light/40"
            ]}
          >
            {link.label}
          </a>
        ))}

        <div class="h-0 border-t-2 border-dashed border-pink-dark/30 my-1 mx-2"></div>

        <a
            href="https://nekkynekko.substack.com/"
            target="_blank"
            rel="noopener noreferrer"
          class="bg-pink-dark text-pink-soft border-2 border-pink-dark font-display font-black text-xs uppercase tracking-wider py-3 rounded-xl text-center shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shadow-pink-dark active:translate-x-0.5 active:translate-y-0.5 active:shadow-none transition-all duration-150"
        >
          Substack ✦
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  toggleBtn?.addEventListener("click", () => {
    const isClosed = mobileMenu?.classList.contains("max-h-0");

    if (isClosed) {
      mobileMenu?.classList.remove("max-h-0", "opacity-0", "pointer-events-none");
      mobileMenu?.classList.add("max-h-96", "opacity-100", "pointer-events-auto");
      iconMenu?.classList.replace("block", "hidden");
      iconClose?.classList.replace("hidden", "block");
    } else {
      mobileMenu?.classList.remove("max-h-96", "opacity-100", "pointer-events-auto");
      mobileMenu?.classList.add("max-h-0", "opacity-0", "pointer-events-none");
      iconMenu?.classList.replace("hidden", "block");
      iconClose?.classList.replace("block", "hidden");
    }
  });
</script>
